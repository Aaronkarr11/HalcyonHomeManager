<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:viewmodels="clr-namespace:HalcyonHomeManager.ViewModels"
             xmlns:model="clr-namespace:HalcyonHomeManager.Entities" 
             x:DataType="viewmodels:ItemRequestViewModel"
             xmlns:controls="clr-namespace:HalcyonHomeManager.Controls"
             x:Class="HalcyonHomeManager.Views.ItemRequestPage"
             Title="Request Items"
             BackgroundImageSource="sky.jpg">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Add New" IconImageSource="ic_action_new.png" Command="{Binding AddItemCommand}"/>
        <ToolbarItem Text="Refresh" IconImageSource="ic_autorenew.png" Command="{Binding OnRefreshCommand}" />
    </ContentPage.ToolbarItems>

    <StackLayout>
        <StackLayout HeightRequest="100" Padding="5,0,0,0" BackgroundColor="CornflowerBlue">
            <Label FontSize="Medium"  Margin="0,5,0,0" HorizontalOptions="CenterAndExpand" FontFamily="Bold" TextColor="White">REQUESTED ITEMS/SUPPLIES</Label>
            <Label FontSize="Small"  Margin="0,10,5,0" Padding="0,0,0,0" HorizontalOptions="CenterAndExpand" HorizontalTextAlignment="Center"  TextColor="White">
                Request needed supplies or tools. View and remove items by checking "complete" Create/refresh items in the above right
            </Label>
        </StackLayout>
        <RefreshView Command="{Binding LoadItemsCommand}" IsRefreshing="{Binding IsBusy, Mode=TwoWay}">

            <CollectionView x:Name="RequestItemsListView" ItemsSource="{Binding RequestItems}" SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <StackLayout Padding="10" x:DataType="model:RequestItems">
                            <Frame CornerRadius="10" Margin="5, 5, 5, 5" HasShadow="True"  BackgroundColor="Azure">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="25" />
                                        <RowDefinition Height="25" />
                                        <RowDefinition Height="25" />
                                        <RowDefinition Height="25" />
                                    </Grid.RowDefinitions>
                                    <Label Grid.Column="0" Grid.Row="0">Item Name:</Label>
                                    <Label Grid.Column="2" Grid.ColumnSpan="2" Grid.Row="0" FontSize="16" FontAttributes="Bold" Text="{Binding Title}"></Label>

                                    <Label Grid.Column="0" Grid.Row="1">Desired Date:</Label>
                                    <Label Grid.Column="2" Grid.ColumnSpan="2" Grid.Row="1" FontSize="16" FontAttributes="Bold" Text="{Binding DesiredDateDisplay}"></Label>
                                    <Label Grid.Column="0" Grid.Row="3">Completed:</Label>
                                    <CheckBox          
                                        Color="Green"
                                        Grid.Column="1" 
                                        Grid.Row="3"
                                        CheckedChanged="FireCompleteCommand"/>
                                </Grid>
                            </Frame>
                        </StackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>


        </RefreshView>
    </StackLayout>


</ContentPage>