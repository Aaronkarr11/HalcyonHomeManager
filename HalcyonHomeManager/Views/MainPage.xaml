<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:HalcyonHomeManager.ViewModels"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.Maui;assembly=LiveChartsCore.SkiaSharpView.Maui"
             x:Class="HalcyonHomeManager.Views.MainPage"
             x:DataType="vm:HomeViewModel"
             Title="{Binding Title}"
             BackgroundImageSource="sky.jpg">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Help" Clicked="HelpButton_Clicked"/>
        <ToolbarItem Text="About" Clicked="AboutButton_Clicked"/>
    </ContentPage.ToolbarItems>


    <ContentPage.Resources>
        <ResourceDictionary>
            <Color x:Key="Accent">#96d1ff</Color>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
            <RowDefinition />
            <RowDefinition />
            <RowDefinition />
        </Grid.RowDefinitions>

        <StackLayout BackgroundColor="{AppThemeBinding Light=#f8f8ff, Dark=#004070}" Margin="0,10,0,0" Grid.Row="0">
            <Label FontSize="Medium" TextColor="{AppThemeBinding Light=#000000, Dark=#ffffff}" FontAttributes="Bold" HorizontalTextAlignment="Center" Text="Work Task Dashboard" BackgroundColor="{AppThemeBinding Light=#f8f8ff, Dark=#2e4e4e}"></Label>
        </StackLayout>
        <StackLayout  BackgroundColor="{AppThemeBinding Light=#f8f8ff, Dark=#004070}" Grid.Row="1" VerticalOptions="FillAndExpand" HorizontalOptions="FillAndExpand" >
            <Label FontSize="Medium"  FontAttributes="Bold" TextColor="{AppThemeBinding Light=#000000, Dark=#ffffff}" HorizontalTextAlignment="Center" Text="{Binding BarGraphTitle}"  BackgroundColor="{AppThemeBinding Light=#f8f8ff, Dark=#004070}"></Label>
            <lvc:CartesianChart VerticalOptions="FillAndExpand"  HorizontalOptions="FillAndExpand"
                  Loaded="OnBarChartLoaded"
                  Series="{Binding BarSeries}"
                  x:Name="BarChart"
                  LegendPosition="Bottom"
                  LegendTextSize="15"
                  BackgroundColor="{AppThemeBinding Light=#f8f8ff, Dark=#004070}"  
                  XAxes="{Binding BarXAxes}"
                  YAxes="{Binding BarYAxes}">
            </lvc:CartesianChart>
        </StackLayout>



        <StackLayout BackgroundColor="{AppThemeBinding Light=#f8f8ff, Dark=#004070}" Grid.Row="2">
            <Label FontSize="Medium" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#000000, Dark=#ffffff}" HorizontalTextAlignment="Center" Text="{Binding PieGraphTitle}"  BackgroundColor="{AppThemeBinding Light=#f8f8ff, Dark=#004070}"></Label>
            <lvc:PieChart  VerticalOptions="FillAndExpand" HorizontalOptions="Fill" Series="{Binding Series}" 
                      x:Name="PieChart"
                      LegendPosition="Right"
                            LegendTextSize="15"
                      TooltipPosition="Right"
                           BackgroundColor="{AppThemeBinding Light=#f8f8ff, Dark=#004070}"
                           
                      />
        </StackLayout>

        <StackLayout BackgroundColor="{AppThemeBinding Light=#f8f8ff, Dark=#004070}" Grid.Row="3">
            <Label FontSize="Medium" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#000000, Dark=#ffffff}" HorizontalTextAlignment="Center" Text="{Binding LineGraphTitle}" ></Label>
            <lvc:CartesianChart  VerticalOptions="FillAndExpand" HorizontalOptions="Fill" 
                                Series="{Binding SeriesCollection}"
                                 Loaded="OnLineChartLoaded"
                                 x:Name="LineChart"
                                 LegendTextSize="15"
                                BackgroundColor="{AppThemeBinding Light=#f8f8ff, Dark=#004070}"
                                XAxes="{Binding XAxes}"
                                YAxes="{Binding YAxes}"/>
        </StackLayout>





    </Grid>

</ContentPage>
